Cell 5 — decode and plot inline:
def read_all_packets():
    packets = []
    with open(LOCAL_FILE, "rb") as f:
        data = f.read()
    i = 0
    while i < len(data):
        pkt_len = int.from_bytes(data[i:i+2], "big")
        raw = data[i+2:i+2+pkt_len]
        packets.append(parse_ccsds_packet(raw))
        i += 2 + pkt_len
    return packets

packets = read_all_packets()
temps = [p["payload"]["temperature_C"] for p in packets]
humidity = [p["payload"]["humidity_percent"] for p in packets]

